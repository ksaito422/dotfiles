{
  "language": "japanese",
  "autoUpdatesChannel": "stable",
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "🤖 Generated with [Claude Code](https://claude.com/claude-code)",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(gh pr view:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf)",
      "Bash(sudo:*)",
      "Bash(bundle install:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm uninstall:*)",
      "Bash(curl:*)",
      "Read(.env.*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\e]777;notify;Claude Code;承認が必要です\\e\\\\' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\e]777;notify;Claude Code;タスクが完了しました\\e\\\\' > /dev/tty"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/work/ghq/github.com/ksaito422/dotfiles/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "japanese",
  "autoUpdatesChannel": "stable"
}

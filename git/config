[init]
    defaultBranch = main
[pull]
    rebase = false
[diff]
    tool = nvim_difftool
[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"
[merge]
    tool = nvimdiff
[mergetool "nvimdiff"]
    cmd = nvim -d $LOCAL $MERGED $REMOTE -c 'wincmd l' -c 'wincmd J'
[diff]
    colorMoved = default

[push]
	default = simple
	autoSetupRemote = true
[fetch]
	prune = true
[ghq]
    root = ~/work/ghq
